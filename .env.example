# === sipgate Credentials ===
SIPGATE_USER=1234567t0
SIPGATE_PASS=your-sipgate-password

# === AI Platform SIP Target ===
# Where should incoming calls be forwarded?
# Examples:
#   ElevenLabs:  sip.rtc.elevenlabs.io
#   Bland AI:    sip.bland.ai
#   Retell:      sip.retellai.com
#   Vapi:        sip.vapi.ai
AI_SIP_HOST=sip.rtc.elevenlabs.io
AI_SIP_PORT=5060
AI_SIP_TRANSPORT=tcp
# TLS options (if supported):
# AI_SIP_PORT=5061
# AI_SIP_TRANSPORT=tls
# Optional: only needed if the AI platform requires SIP digest auth
# AI_SIP_USER=
# AI_SIP_PASS=
