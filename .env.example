# === sipgate Credentials ===
SIPGATE_USER=1234567t0
SIPGATE_PASS=dein-sipgate-passwort

# === AI-Plattform SIP-Ziel ===
# Wohin sollen eingehende Calls weitergeleitet werden?
# Beispiele:
#   ElevenLabs:  sip.rtc.elevenlabs.io
#   Bland AI:    sip.bland.ai
#   Retell:      sip.retellai.com
#   Vapi:        sip.vapi.ai
AI_SIP_HOST=sip.rtc.elevenlabs.io
AI_SIP_PORT=5060
AI_SIP_TRANSPORT=tcp
# == TLS-Optionen (falls unterstützt) ==
# AI_SIP_PORT=5061
# AI_SIP_TRANSPORT=tls
# Optional: Nur ausfüllen wenn die AI-Plattform Digest-Auth erfordert
# AI_SIP_USER=
# AI_SIP_PASS=
